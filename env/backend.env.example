# Server configuration
PORT=3000
NODE_ENV=development # production | development | test
TRUST_PROXY=false # true (prod) | false (dev)

# PostgreSQL database configuration
# PgBouncer (6432) forwards to Postgres on port 5432 inside Docker.
DB_USER=project_dev
DB_PASS=dev_password
DB_HOST=localhost
DB_PORT=5433
DB_NAME=project_dev

# Pool tuning
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=5000

# Security configuration
JWT_SECRET=super_secret_jwt_key_for_development_only
# JWT access tokens (mobile/API)
JWT_ACCESS_EXPIRES_IN=900          # 15 minutes (seconds)

# Argon2id configuration
ARGON2_TIME_COST=3 # Iterations
ARGON2_MEMORY_EXP=16 # memoryCost = 2^16 (65536 KiB)
ARGON2_PARALLELISM=1 # Threads

# CORS configuration (allow local frontend apps)
CORS_ORIGIN=http://localhost:5173

# Additional logging
LOG_LEVEL=debug # debug (dev) | info (prod) | warn | error
LOG_PETICION_HOSTS=localhost # Example: api.project.com,localhost

